[Unit]
Description=CaBrain deploy webhook receiver (GitHub push → docker build+restart)
After=network.target docker.service

[Service]
Type=simple
User=root
Group=root
Environment=DOCKER_HOST=unix:///mnt/wsl/docker-desktop/shared-sockets/host-services/docker.proxy.sock
ExecStart=/usr/bin/webhook -verbose -hooks /home/fadymondy/services/cabrain-deploy/hooks.yaml -hotreload -ip 0.0.0.0 -port 9800
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
