# ─── Core ────────────────────────────────────────────────────────────────
APP_ENV=development                 # development | production (production fails closed on secrets)
APP_URL=http://localhost:8080       # public base URL (OAuth/SSO callbacks)
ADDR=:8080

# ─── Database (togo-postgres) ────────────────────────────────────────────────────
# Chosen at `togo new` time. Switch later via DB_DRIVER + DATABASE_URL.
# For the docker stacks (postgres / togo-postgres / supabase / mysql / mongodb): `togo db:up`.
DB_DRIVER=pgx
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cabrain?sslmode=disable

# ─── Logging (togo-framework/log) ──────────────────────────────────────────
LOG_LEVEL=info                      # debug | info | warn | error
LOG_FORMAT=text                     # text | json
# LOG_FILE=storage/logs/app.log     # file sink (default: stderr)
# LOG_SERVICE=my-app

# ─── i18n (togo-framework/i18n) ────────────────────────────────────────────
LOCALE=en
LOCALE_DIR=lang

# ─── Cache (togo-framework/cache) ──────────────────────────────────────────
CACHE_DRIVER=memory                 # memory | file | database | redis (plugin)
# CACHE_DIR=storage/cache           # for the file driver

# ─── Storage / Realtime ────────────────────────────────────────────────────
STORAGE_DIR=storage
# REALTIME_SECRET=                  # togo-framework/realtime-ws private-channel tickets

# ─── Auth (togo-framework/auth) ────────────────────────────────────────────
AUTH_SECRET=                        # REQUIRED in production (>= 32 bytes)
AUTH_DRIVER=base                    # base (JWT) | supabase
AUTH_TTL_HOURS=24
AUTH_MIN_PASSWORD=8
SESSION_DRIVER=cookie               # cookie (stateless) | database | file | redis (plugin)
# SESSION_DIR=storage/sessions      # for the file session driver
COOKIE_SECURE=                      # 1 to force Secure cookies (auto-on in production)
CORS_ORIGINS=                       # comma-separated allowed origins (empty = same-origin)

# OAuth drivers (togo-framework/auth-oauth)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_FACEBOOK_CLIENT_SECRET=
# Firebase (togo-framework/auth-firebase)
# FIREBASE_PROJECT_ID=
# WorkOS SSO (togo-framework/auth-workos)
# WORKOS_CLIENT_ID=
# WORKOS_API_KEY=
# WORKOS_CONNECTION=

# Supabase auth (togo-framework/plugin-auth-supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ─── Mail (togo-framework/mail) ────────────────────────────────────────────
MAIL_DRIVER=                        # smtp | log (default: log in dev, smtp if MAIL_HOST set)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_ENCRYPTION=starttls            # starttls | tls | none
# RESEND_API_KEY=                   # togo-framework/mail-resend (MAIL_DRIVER=resend)

# ─── Search (togo-framework/search) ────────────────────────────────────────
SEARCH_DRIVER=paradedb              # paradedb (default) | elasticsearch | opensearch
# SEARCH_URL=http://localhost:9200  # for elasticsearch/opensearch
# SEARCH_USERNAME=
# SEARCH_PASSWORD=

# ─── Workers (togo-framework/worker) ───────────────────────────────────────
WORKER_AUTOSTART=true               # set false to disable background workers

# ─── MCP / AI (togo-framework/mcp) ─────────────────────────────────────────
# TOGO_MCP_ROLE=admin               # admin | user (toolset scope; set by mcp:install)
# TOGO_AI_MODEL=                     # optional model override

# ─── Frontend (web/.env mirrors NEXT_PUBLIC_*) ─────────────────────────────
NEXT_PUBLIC_API_ORIGIN=http://localhost:8080
NEXT_PUBLIC_LOCALE=en
# NEXT_PUBLIC_TOGO_RESOURCES=posts   # dashboard admin resource list

# ═══════════════════════════════════════════════════════════════════════════
# CaBrain — infra inputs (SPEC §1.5 / infra §4 bundle). Provisioned by the infra
# agent; secrets live root-owned at /mnt/c/services/cabrain/{.pg-secrets,.minio-secrets}
# and are injected into the container env — NEVER commit real values here.
# All hostnames resolve only inside Docker network `stack_stacknet`, so the app
# runs as a container on that network.
# ═══════════════════════════════════════════════════════════════════════════

# --- Postgres (togo-postgres) --- the app reads DATABASE_URL (togo.yaml: ${DATABASE_URL}).
# Infra exports CABRAIN_DATABASE_URL; map it → DATABASE_URL in the container env.
# CABRAIN_DATABASE_URL=postgresql://cabrain:<secret>@pg:5432/cabrain
CABRAIN_DB_SLEEP_ROLE=cabrain_sleep         # analytics/consolidation role (N1 isolation)

# --- Cognee engine (wrapped cognify engine) ---
COGNEE_API_URL=http://cognee:8000
# COGNEE_API_TOKEN=<secret — from .pg-secrets>
COGNEE_MCP_URL=                              # not deployed (optional per brief)

# --- TEI (self-hosted embeddings + rerank on RTX 3060) ---
TEI_EMBEDDINGS_URL=http://tei-embed:80
TEI_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-0.6B   # 1024-dim — LOCKED (schema vector(1024))
TEI_RERANKER_URL=http://tei-rerank:80
TEI_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Extraction LLM (structured-output for the retain write-decision, §4.1) ---
EXTRACTION_LLM_PROVIDER=ollama
EXTRACTION_LLM_URL=http://ollama:11434
EXTRACTION_LLM_MODEL=mistral:7b-instruct     # placeholder → override to gpt-oss:20b once pulled
EXTRACTION_LLM_API_KEY=                       # unused for ollama
EXTRACTION_LLM_FALLBACK_BASE_URL=             # optional cheap-API fallback
EXTRACTION_LLM_FALLBACK_API_KEY=

# --- Cold tier (Iceberg/Parquet on MinIO; R2/GCS-compatible) ---
COLD_STORE_ENDPOINT=http://minio:9000
COLD_STORE_BUCKET=cabrain-cold
COLD_STORE_REGION=auto
COLD_STORE_ACCESS_KEY=cabrain-app
# COLD_STORE_SECRET_KEY=<secret — from .minio-secrets>

# --- Networking ---
CABRAIN_INTERNAL_NETWORK=stack_stacknet
CABRAIN_APP_HOSTNAME=cabrain.fadymondy.com   # NPM route (pending)
COGNEE_DOCS_HOSTNAME=cognee.fadymondy.com    # NPM route (pending)
